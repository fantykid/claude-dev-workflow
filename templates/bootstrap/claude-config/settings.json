{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Bash(pwd)",
      "Bash(ls /workspace*)",
      "Bash(ls -*)",
      "Bash(find /workspace*)",
      "Bash(mkdir /workspace*)",
      "Bash(cp /workspace*)",
      "Bash(chmod /workspace*)",
      "Bash(cat /workspace*)",
      "Bash(sed /workspace*)",
      "Bash(basename *)",
      "Bash(echo *)",
      "Bash(printenv PROJECT_NAME)",
      "Bash(printenv HOST_PROJECT_DIR)",
      "Bash(date *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)",
      "Bash(rm -rf *)",
      "Bash(rm --recursive *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker *)",
      "Bash(git *)"
    ],
    "additionalDirectories": []
  }
}
